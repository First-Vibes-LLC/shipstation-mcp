# ShipStation API credentials
# Obtain from: ShipStation → Settings → Account → API Settings
SSKEY=your_shipstation_api_key
SSSEC=your_shipstation_api_secret

# Optional: override the ShipStation API base URL
# SSURL=https://ssapi.shipstation.com

# MCP server bind address (defaults work for Docker)
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8000

# Authentication
# Set a static Bearer token clients must present on protected MCP routes.
# OAuth 2.0 (authorization_code + PKCE) is also supported — see README.
MCP_AUTH_TOKEN=your_secure_token_here

# Public base URL of this server — required for OAuth discovery redirects.
# Use an ngrok/tunnel URL for local testing with Claude or LM Studio.
MCP_BASE_URL=http://localhost:8000
